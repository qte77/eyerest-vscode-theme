  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.quoted.docstring"],
      "settings": {
        "foreground": "#7A9A7A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted.single", "string.quoted.double"],
      "settings": {
        "foreground": "#3A7A3A"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#4A7A1A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#3A7A38"
      }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": {
        "foreground": "#1A5A2A"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#4A6A4A"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#5A7A2A"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#1A5A2A"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#5A7A2A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#2A4A2A"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#2A7A28",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#5A7A2A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["punctuation", "punctuation.definition.tag", "meta.tag"],
      "settings": {
        "foreground": "#4A6A4A"
      }
    },
    {
      "scope": ["meta.import", "keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#5A7A2A"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#1A5A2A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#2A4A2A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#2A4A2A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": ["markup.list", "beginning.punctuation.definition.list"],
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#3A7A3A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#8A3A2A"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#3A7A3A"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["meta.object-literal.key", "support.type.property-name.json"],
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": "support.type.property-name.css",
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": "support.constant.property-value.css",
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": "entity.other.attribute-name.class.css",
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": "entity.other.attribute-name.id.css",
      "settings": {
        "foreground": "#5A7A2A"
      }
    },
    {
      "scope": "source.css entity.name.tag",
      "settings": {
        "foreground": "#4A7A1A"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#2A7A28"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#7A6A1A"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#8A3A2A"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#6A4A28"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#2A7A28",
    "function.declaration": { "foreground": "#2A7A28", "fontStyle": "bold" },
    "method": "#2A7A28",
    "variable": "#2A4A2A",
    "variable.readonly": "#4A7A1A",
    "parameter": { "foreground": "#2A7A28", "fontStyle": "italic" },
    "property": "#4A6A4A",
    "property.readonly": "#4A7A1A",
    "type": "#4A7A1A",
    "class": "#4A7A1A",
    "interface": { "foreground": "#4A7A1A", "fontStyle": "italic" },
    "enum": "#4A7A1A",
    "enumMember": "#5A7A2A",
    "namespace": "#4A7A1A",
    "decorator": "#5A7A2A",
    "macro": "#5A7A2A",
    "keyword": "#1A5A2A",
    "comment": { "foreground": "#7A9A7A", "fontStyle": "italic" },
    "string": "#3A7A3A",
    "number": "#4A7A1A",
    "regexp": "#2A7A28",
    "operator": "#4A6A4A",
    "*.deprecated": { "foreground": "#7A9A7A", "fontStyle": "strikethrough" }
  }
}
