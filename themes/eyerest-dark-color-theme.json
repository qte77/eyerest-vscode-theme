  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.quoted.docstring"],
      "settings": { "foreground": "#807858", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted.single", "string.quoted.double"],
      "settings": { "foreground": "#8AA860" }
    },
    {
      "scope": "string.regexp",
      "settings": { "foreground": "#A0B070" }
    },
    {
      "scope": "constant.numeric",
      "settings": { "foreground": "#C8B868" }
    },
    {
      "scope": "constant.language",
      "settings": { "foreground": "#C8B868", "fontStyle": "italic" }
    },
    {
      "scope": "constant.character.escape",
      "settings": { "foreground": "#C89878" }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#C09070" }
    },
    {
      "scope": "keyword.operator",
      "settings": { "foreground": "#A89878" }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#B0A060" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#C8A858" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#A8B870" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#C09070" }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#C8B868", "fontStyle": "italic" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#D8D0B8" }
    },
    {
      "scope": "variable.parameter",
      "settings": { "foreground": "#C89878", "fontStyle": "italic" }
    },
    {
      "scope": "variable.language",
      "settings": { "foreground": "#B0A060", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation", "punctuation.definition.tag", "meta.tag"],
      "settings": { "foreground": "#A89878" }
    },
    {
      "scope": ["meta.import", "keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": { "foreground": "#A0B070" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#A8B870" }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#B0A060" }
    },
    {
      "scope": "markup.heading",
      "settings": { "foreground": "#C09070", "fontStyle": "bold" }
    },
    {
      "scope": "markup.bold",
      "settings": { "foreground": "#D8D0B8", "fontStyle": "bold" }
    },
    {
      "scope": "markup.italic",
      "settings": { "foreground": "#D8D0B8", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#C8B868" }
    },
    {
      "scope": ["markup.list", "beginning.punctuation.definition.list"],
      "settings": { "foreground": "#A0B070" }
    },
    {
      "scope": "markup.quote",
      "settings": { "foreground": "#8AA860", "fontStyle": "italic" }
    },
    {
      "scope": "markup.deleted",
      "settings": { "foreground": "#C08060" }
    },
    {
      "scope": "markup.inserted",
      "settings": { "foreground": "#8AA860" }
    },
    {
      "scope": "markup.underline",
      "settings": { "fontStyle": "underline" }
    },
    {
      "scope": ["meta.object-literal.key", "support.type.property-name.json"],
      "settings": { "foreground": "#C89878" }
    },
    {
      "scope": "support.type.property-name.css",
      "settings": { "foreground": "#C89878" }
    },
    {
      "scope": "support.constant.property-value.css",
      "settings": { "foreground": "#C8B868" }
    },
    {
      "scope": "entity.other.attribute-name.class.css",
      "settings": { "foreground": "#A8B870" }
    },
    {
      "scope": "entity.other.attribute-name.id.css",
      "settings": { "foreground": "#C8A858" }
    },
    {
      "scope": "source.css entity.name.tag",
      "settings": { "foreground": "#A8B870" }
    },
    {
      "scope": "token.info-token",
      "settings": { "foreground": "#8AA860" }
    },
    {
      "scope": "token.warn-token",
      "settings": { "foreground": "#C8B868" }
    },
    {
      "scope": "token.error-token",
      "settings": { "foreground": "#C08060" }
    },
    {
      "scope": "token.debug-token",
      "settings": { "foreground": "#B0A060" }
    }
  ],
  "semanticTokenColors": {
    "function": "#C8A858",
    "function.declaration": { "foreground": "#C8A858", "fontStyle": "bold" },
    "method": "#C8A858",
    "variable": "#D8D0B8",
    "variable.readonly": "#C8B868",
    "parameter": { "foreground": "#C89878", "fontStyle": "italic" },
    "property": "#A89878",
    "property.readonly": "#C8B868",
    "type": "#A8B870",
    "class": "#A8B870",
    "interface": { "foreground": "#A8B870", "fontStyle": "italic" },
    "enum": "#A8B870",
    "enumMember": "#C8B868",
    "namespace": "#A8B870",
    "decorator": "#B0A060",
    "macro": "#B0A060",
    "keyword": "#C09070",
    "comment": { "foreground": "#807858", "fontStyle": "italic" },
    "string": "#8AA860",
    "number": "#C8B868",
    "regexp": "#A0B070",
    "operator": "#A89878",
    "*.deprecated": { "foreground": "#706848", "fontStyle": "strikethrough" }
  }
}
