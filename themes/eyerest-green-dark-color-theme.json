  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.quoted.docstring"],
      "settings": {
        "foreground": "#5A7A5A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted.single", "string.quoted.double"],
      "settings": {
        "foreground": "#6AAA5A"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#5AAA8A"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#B8D880",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#8ACAB0"
      }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": {
        "foreground": "#9EE0A0"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#7AA878"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#C4D89A"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#8ACAB0"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#9EE0A0"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#C4D89A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#A8D4A2"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#8ACAB0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#C4D89A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["punctuation", "punctuation.definition.tag", "meta.tag"],
      "settings": {
        "foreground": "#7AA878"
      }
    },
    {
      "scope": ["meta.import", "keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#5AAA8A"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#C4D89A"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#9EE0A0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#A8D4A2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#A8D4A2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": ["markup.list", "beginning.punctuation.definition.list"],
      "settings": {
        "foreground": "#5AAA8A"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#6AAA5A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#D47A6A"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#6AAA5A"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["meta.object-literal.key", "support.type.property-name.json"],
      "settings": {
        "foreground": "#8ACAB0"
      }
    },
    {
      "scope": "support.type.property-name.css",
      "settings": {
        "foreground": "#8ACAB0"
      }
    },
    {
      "scope": "support.constant.property-value.css",
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": "entity.other.attribute-name.class.css",
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": "entity.other.attribute-name.id.css",
      "settings": {
        "foreground": "#C4D89A"
      }
    },
    {
      "scope": "source.css entity.name.tag",
      "settings": {
        "foreground": "#B8D880"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#5AAA8A"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#C4B870"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#D47A6A"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#AA8AAA"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#8ACAB0",
    "function.declaration": { "foreground": "#8ACAB0", "fontStyle": "bold" },
    "method": "#8ACAB0",
    "variable": "#A8D4A2",
    "variable.readonly": "#B8D880",
    "parameter": { "foreground": "#8ACAB0", "fontStyle": "italic" },
    "property": "#7AA878",
    "property.readonly": "#B8D880",
    "type": "#B8D880",
    "class": "#B8D880",
    "interface": { "foreground": "#B8D880", "fontStyle": "italic" },
    "enum": "#B8D880",
    "enumMember": "#C4D89A",
    "namespace": "#B8D880",
    "decorator": "#C4D89A",
    "macro": "#C4D89A",
    "keyword": "#9EE0A0",
    "comment": { "foreground": "#5A7A5A", "fontStyle": "italic" },
    "string": "#6AAA5A",
    "number": "#B8D880",
    "regexp": "#5AAA8A",
    "operator": "#7AA878",
    "*.deprecated": { "foreground": "#5A7A5A", "fontStyle": "strikethrough" }
  }
}
